<script>
  // ---------- Intro open sequence ----------
  const intro = document.getElementById('intro');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let opened = false;

  function spawnConfetti(){
    const colors = ['#C9A227','#A47E1B','#1B3653','#F2E3C8'];
    for(let i=0;i<22;i++){
      const p = document.createElement('div');
      p.className = 'confetti-piece';
      const angle = Math.random()*Math.PI*2;
      const dist = 140 + Math.random()*220;
      const dx = Math.cos(angle)*dist, dy = Math.sin(angle)*dist - 60;
      p.style.background = colors[i % colors.length];
      p.style.transform = 'translate(-50%,-50%)';
      p.style.transition = 'transform 1s cubic-bezier(.2,.7,.3,1), opacity 1s ease';
      p.style.opacity = '1';
      document.body.appendChild(p);
      requestAnimationFrame(()=>{
        p.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px)) rotate(${Math.random()*360}deg)`;
        p.style.opacity = '0';
      });
      setTimeout(()=>p.remove(), 1100);
    }
  }

  function openInvite(){
    if (opened) return;
    opened = true;
    spawnConfetti();
    intro.classList.add('opening');
    document.body.classList.remove('locked');
    setTimeout(()=>{ intro.classList.add('fading'); }, 1100);
    setTimeout(()=>{ intro.style.display='none'; }, 1550);
  }

  if (reduceMotion) {
    intro.style.display = 'none';
    document.body.classList.remove('locked');
    opened = true;
  } else {
    intro.addEventListener('click', openInvite);
    setTimeout(openInvite, 5000);
  }

  // ---------- Scroll reveal ----------
  const revealEls = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.15 });
    revealEls.forEach(el => io.observe(el));
  } else {
    revealEls.forEach(el => el.classList.add('in'));
  }

  // ---------- Flip countdown ----------
  function getEventDate(){
    const now = new Date();
    let year = now.getFullYear();
    let target = new Date(year + '-08-25T11:00:00+05:30');
    if (target.getTime() < now.getTime()) target = new Date((year+1) + '-08-25T11:00:00+05:30');
    return target;
  }
  const eventDate = getEventDate();
  const prev = { d:null, h:null, m:null, s:null };

  function setDigit(el, key, val){
    if (prev[key] === val) return;
    prev[key] = val;
    el.classList.add('flip');
    setTimeout(()=>{ el.textContent = val; }, 250);
    setTimeout(()=>{ el.classList.remove('flip'); }, 540);
  }

  function updateCountdown(){
    const now = new Date();
    let diff = eventDate.getTime() - now.getTime();
    if (diff < 0) diff = 0;
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const mins = Math.floor((diff % 3600000) / 60000);
    const secs = Math.floor((diff % 60000) / 1000);
    setDigit(document.getElementById('cd-days'), 'd', String(days));
    setDigit(document.getElementById('cd-hours'), 'h', String(hours).padStart(2,'0'));
    setDigit(document.getElementById('cd-mins'), 'm', String(mins).padStart(2,'0'));
    setDigit(document.getElementById('cd-secs'), 's', String(secs).padStart(2,'0'));
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ---------- Add to calendar ----------
  document.getElementById('add-cal').addEventListener('click', function(e){
    e.preventDefault();
    const start = eventDate;
    const end = new Date(start.getTime() + 90*60000);
    function pad(n){ return String(n).padStart(2,'0'); }
    function fmt(d){ return d.getUTCFullYear()+pad(d.getUTCMonth()+1)+pad(d.getUTCDate())+'T'+pad(d.getUTCHours())+pad(d.getUTCMinutes())+'00Z'; }
    const ics = [
      'BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Baptism Invite//EN','BEGIN:VEVENT',
      'UID:' + Date.now() + '@anjobaptism',
      'DTSTAMP:' + fmt(new Date()),
      'DTSTART:' + fmt(start),
      'DTEND:' + fmt(end),
      'SUMMARY:Holy Baptism of Anjo P. Jomon',
      'DESCRIPTION:Requesting your prayers and presence. Reception to follow at St. Thomas Marthoma Syrian Church Hall, Kattunilem Palli, Niranam.',
      'LOCATION:St. Joseph Malankara Catholic Church, Niranam Central',
      'END:VEVENT','END:VCALENDAR'
    ].join('\r\n');
    const blob = new Blob([ics], { type: 'text/calendar' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'Anjo-Baptism.ics';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
</script>

