<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Holy Baptism — Anjo P. Jomon</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Pinyon+Script&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --cream:#FBF3E6;
    --cream-deep:#F2E3C8;
    --paper-line:#E6D3AC;
    --sage:#8C9C7E;
    --sage-deep:#5E6F52;
    --sage-pale:#C9D4BD;
    --gold:#C9A227;
    --gold-deep:#A47E1B;
    --navy:#1B3653;
    --navy-soft:#3F5973;
    --blush:#E8B7AE;
    --dusk-blue:#BCD0DC;
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    font-family:"Jost", sans-serif;
    background:var(--cream);
    color:var(--navy);
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  body.locked{ overflow:hidden; height:100vh; }
  img,svg{ display:block; }
  .script{ font-family:"Pinyon Script", cursive; font-weight:400; }
  .serif{ font-family:"Cormorant Garamond", serif; }

  /* ===================== INTRO — CHURCH ENTRANCE ===================== */
  #intro{
    position:fixed; inset:0; z-index:9999; display:flex; align-items:center; justify-content:center;
    background: linear-gradient(180deg, #DCE7ED 0%, #ECE9DC 55%, #F6EFDD 100%);
    overflow:auto;
  }
  #intro.fading{ opacity:0; transition:opacity .45s ease; }

  .church-wrap{ position:relative; z-index:2; display:flex; flex-direction:column; align-items:center; padding:26px 20px; }
  .church-wrap::before{
    content:""; position:absolute; top:50%; left:50%; width:120%; height:120%;
    transform:translate(-50%,-50%) scale(0.55); border-radius:50%;
    background:radial-gradient(circle, rgba(255,248,222,0.95), rgba(255,248,222,0) 65%);
    opacity:0; z-index:0; pointer-events:none;
    transition:opacity 1s ease, transform 1.5s cubic-bezier(.2,.7,.3,1);
  }
  #intro.opening .church-wrap::before{ opacity:1; transform:translate(-50%,-50%) scale(1.25); }
  .church-text, .church-text2, .archway{ position:relative; z-index:2; }

  .church-text, .church-text2{ transition:opacity .3s ease; display:flex; flex-direction:column; align-items:center; }
  #intro.opening .church-text, #intro.opening .church-text2{ opacity:0; }

  .spire-cross{ width:50px; }
  .spire-cross svg{ width:100%; height:auto; }

  .archway{
    position:relative; margin-top:10px;
    width:min(58vw,250px); height:min(46vh,340px);
    border-radius: 50% 50% 4px 4px / 28% 28% 4px 4px;
    overflow:hidden;
    box-shadow: 0 18px 46px rgba(63,89,115,0.22), 0 0 0 7px var(--cream), 0 0 0 9px var(--gold);
  }
  .archway::after{
    content:""; position:absolute; inset:0;
    background:radial-gradient(circle at 50% 55%, rgba(255,252,235,0.95), rgba(255,252,235,0) 60%);
    opacity:0; transition:opacity .9s ease .15s; pointer-events:none; z-index:3;
  }
  #intro.opening .archway::after{ opacity:1; }
  .archway .door{
    position:absolute; top:0; bottom:0; width:50%;
    background:
      repeating-linear-gradient(90deg, rgba(164,126,27,0.14) 0 2px, transparent 2px 24px),
      linear-gradient(160deg, #FBF3E6 0%, #F2E3C8 55%, #E3CC9C 130%);
    transition: transform 1.1s cubic-bezier(.65,0,.35,1);
  }
  .archway .door.left{ left:0; border-right:1.4px solid rgba(164,126,27,0.55); }
  .archway .door.right{ right:0; border-left:1.4px solid rgba(164,126,27,0.55); }
  .door-handle{ position:absolute; top:50%; width:9px; height:9px; border-radius:50%; border:2px solid var(--gold-deep); background:#F2E3C8; }
  .door.left .door-handle{ right:13px; }
  .door.right .door-handle{ left:13px; }
  #intro.opening .archway .door.left{ transform:translateX(-100%); }
  #intro.opening .archway .door.right{ transform:translateX(100%); }

  .intro-eyebrow{ margin-top:10px; font-size:12px; letter-spacing:5px; text-transform:uppercase; color:var(--navy-soft); font-weight:500; }
  .intro-name{ margin-top:16px; font-family:"Pinyon Script", cursive; font-size:clamp(34px,9vw,46px); color:var(--navy); line-height:1; }
  .tap-hint{ margin-top:18px; display:flex; flex-direction:column; align-items:center; gap:9px; color:var(--gold-deep); }
  .tap-circle{ width:50px; height:50px; border-radius:50%; border:1.2px solid var(--gold); display:flex; align-items:center; justify-content:center; animation: pulseRing 2s ease-in-out infinite; }
  .tap-circle svg{ width:17px; height:17px; }
  @keyframes pulseRing{ 0%,100%{ box-shadow:0 0 0 0 rgba(196,160,60,0.35); } 50%{ box-shadow:0 0 0 12px rgba(196,160,60,0); } }
  .tap-label{ font-size:11px; letter-spacing:3px; text-transform:uppercase; }

  .confetti-piece{ position:fixed; top:50%; left:50%; z-index:10000; width:7px; height:7px; pointer-events:none; border-radius:50%; }

  /* ===================== LEAF CORNER MOTIF ===================== */
  .leaf-corner{ position:absolute; width:170px; height:170px; pointer-events:none; }
  .leaf-corner svg{ width:100%; height:100%; }
  .leaf-corner.tl{ left:-12px; top:-12px; }
  .leaf-corner.tr{ right:-12px; top:-12px; transform:scaleX(-1); }
  .leaf-corner.bl{ left:-12px; bottom:-12px; transform:scaleY(-1); }
  .leaf-corner.br{ right:-12px; bottom:-12px; transform:scale(-1,-1); }
  .leaf-corner.small{ width:110px; height:110px; }

  /* ===================== HERO ===================== */
  .hero{
    position:relative; min-height:100vh; min-height:100svh;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; padding:70px 26px 50px; overflow:hidden;
    background:
      radial-gradient(520px 420px at 92% 6%, rgba(188,208,220,0.55), rgba(188,208,220,0) 65%),
      radial-gradient(480px 420px at 4% 96%, rgba(188,208,220,0.45), rgba(188,208,220,0) 65%),
      var(--cream);
  }
  .dove{ position:absolute; width:64px; opacity:.85; }
  .dove svg{ width:100%; height:auto; }

  .invite-line{ position:relative; z-index:1; font-family:"Cormorant Garamond", serif; font-style:italic; font-weight:500; font-size:clamp(15px,4vw,18px); color:var(--navy-soft); }

  .cross-flourish{ position:relative; z-index:1; margin-top:22px; width:78px; }
  .cross-flourish svg{ width:100%; height:auto; }

  .baptism-emblem{ position:relative; z-index:1; margin-top:26px; width:min(46vw,180px); }
  .baptism-emblem svg{ width:100%; height:auto; }
  .drip{ transform-box:fill-box; transform-origin:center; animation: dripFall 3s ease-in infinite; }
  .drip.d2{ animation-delay:1s; }
  .drip.d3{ animation-delay:2s; }
  @keyframes dripFall{
    0%{ transform:translateY(0); opacity:0; }
    8%{ opacity:1; }
    58%{ transform:translateY(68px); opacity:1; }
    66%{ opacity:0; }
    100%{ transform:translateY(68px); opacity:0; }
  }
  .ripple{ transform-box:fill-box; transform-origin:center; opacity:0; animation: rippleGrow 3s ease-out infinite; }
  .ripple.r2{ animation-delay:1.5s; }
  @keyframes rippleGrow{
    0%{ transform:scale(0.3); opacity:0; }
    60%{ transform:scale(0.3); opacity:0; }
    66%{ transform:scale(0.55); opacity:.55; }
    100%{ transform:scale(2.3); opacity:0; }
  }

  .holy{ position:relative; z-index:1; margin-top:18px; font-family:"Cormorant Garamond", serif; font-style:italic; font-weight:500; font-size:clamp(22px,5.6vw,28px); color:var(--gold-deep); }
  .baptism-word{ position:relative; z-index:1; margin-top:2px; font-family:"Pinyon Script", cursive; font-size:clamp(72px,20vw,128px); color:var(--navy); line-height:1; }

  .of-son{ position:relative; z-index:1; margin-top:10px; display:flex; align-items:center; justify-content:center; gap:14px; }
  .of-son .line{ width:38px; height:1px; background:var(--gold); }
  .of-son span.txt{ font-family:"Cormorant Garamond", serif; font-style:italic; font-size:clamp(15px,4vw,18px); color:var(--navy-soft); }

  .baby-name{ position:relative; z-index:1; margin-top:14px; font-family:"Cormorant Garamond", serif; font-weight:700; font-size:clamp(30px,8vw,46px); letter-spacing:3px; color:var(--gold-deep); }

  .heart-rule{ position:relative; z-index:1; margin-top:18px; display:flex; align-items:center; justify-content:center; gap:10px; }
  .heart-rule .line{ width:54px; height:1px; background:linear-gradient(90deg, transparent, var(--gold)); }
  .heart-rule .line.r{ background:linear-gradient(90deg, var(--gold), transparent); }
  .heart-rule svg{ width:10px; height:10px; }

  /* flip countdown */
  .countdown{ position:relative; z-index:1; margin-top:30px; display:flex; align-items:flex-start; justify-content:center; gap:12px; }
  .unit{ display:flex; flex-direction:column; align-items:center; }
  .flipcard{ min-width:56px; padding:10px 12px 8px; background:#fff; border-radius:4px; box-shadow:0 8px 20px rgba(27,54,83,.10); border:1px solid var(--paper-line); }
  .digit-val{ display:block; font-family:"Cormorant Garamond", serif; font-weight:600; font-size:clamp(24px,6.6vw,32px); line-height:1; color:var(--navy); transform-style:preserve-3d; backface-visibility:hidden; }
  .digit-val.flip{ animation:flipTick .52s ease; }
  @keyframes flipTick{ 0%{ transform:rotateX(0deg); opacity:1;} 48%{ transform:rotateX(-95deg); opacity:.25;} 52%{ transform:rotateX(85deg); opacity:.25;} 100%{ transform:rotateX(0deg); opacity:1;} }
  .lbl{ margin-top:7px; font-size:10px; letter-spacing:2px; color:var(--navy-soft); text-transform:uppercase; }
  .colon{ align-self:center; margin-top:4px; color:var(--gold); font-size:18px; }

  .scroll-hint{ position:relative; z-index:1; margin-top:38px; display:flex; flex-direction:column; align-items:center; gap:8px; color:var(--navy-soft); opacity:.75; }
  .scroll-hint span{ font-size:10px; letter-spacing:3px; text-transform:uppercase; }
  .scroll-hint .arrow{ width:12px; height:12px; border-right:1.2px solid var(--gold); border-bottom:1.2px solid var(--gold); transform:rotate(45deg); animation:bob 2.2s ease-in-out infinite; }
  @keyframes bob{ 0%,100%{ transform:rotate(45deg) translate(0,0);} 50%{ transform:rotate(45deg) translate(4px,4px);} }

  /* ===================== SECTIONS ===================== */
  section{ padding:74px 26px; max-width:600px; margin:0 auto; position:relative; }
  .reveal{ opacity:0; transform:translateY(22px); transition:opacity .8s ease, transform .8s ease; }
  .reveal.in{ opacity:1; transform:translateY(0); }

  .sec-head{ text-align:center; margin-bottom:38px; }
  .sec-eyebrow{ font-size:12px; letter-spacing:4px; text-transform:uppercase; color:var(--gold-deep); font-weight:500; }
  .sec-title{ margin-top:8px; font-family:"Cormorant Garamond", serif; font-weight:600; font-style:italic; font-size:clamp(26px,6vw,34px); color:var(--navy); }

  .info-row{ display:flex; gap:18px; align-items:flex-start; padding:20px 0; border-bottom:1px solid var(--paper-line); }
  .info-row:last-of-type{ border-bottom:none; }
  .info-row .icon{ width:42px; height:42px; flex:none; border-radius:50%; display:flex; align-items:center; justify-content:center; background:var(--navy); }
  .info-row.gold-icon .icon{ background:transparent; border:1.2px solid var(--gold); }
  .info-row .icon svg{ width:20px; height:20px; }
  .info-row .label{ font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--gold-deep); font-weight:500; margin-bottom:4px; }
  .info-row .value{ font-family:"Cormorant Garamond", serif; font-weight:500; font-size:clamp(18px,4.3vw,22px); color:var(--navy); line-height:1.32; }
  .info-row .sub{ margin-top:3px; font-size:13px; color:var(--navy-soft); font-family:"Jost",sans-serif; }

  .heart-divider{ display:flex; align-items:center; justify-content:center; gap:10px; margin:8px 0 22px; }
  .heart-divider .line{ width:60px; height:1px; background:linear-gradient(90deg, transparent, var(--gold)); }
  .heart-divider .line.r{ background:linear-gradient(90deg, var(--gold), transparent); }
  .heart-divider svg{ width:10px; height:10px; }

  .actions{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; margin-top:30px; }
  .btn{ display:inline-flex; align-items:center; gap:9px; padding:13px 24px; font-family:"Jost", sans-serif; font-size:12px; letter-spacing:2px; text-transform:uppercase; font-weight:500; text-decoration:none; border-radius:30px; cursor:pointer; border:none; transition:transform .25s ease, box-shadow .25s ease; }
  .btn:hover{ transform:translateY(-2px); }
  .btn.primary{ background:linear-gradient(120deg,var(--gold),var(--gold-deep)); color:#fff; box-shadow:0 10px 20px rgba(164,126,27,.32); }
  .btn.ghost{ background:#fff; color:var(--navy); border:1px solid var(--paper-line); }
  .btn svg{ width:14px; height:14px; flex:none; }

  .blessing-sec{ text-align:center; }
  .blessing-quote{ font-family:"Cormorant Garamond", serif; font-style:italic; font-weight:500; font-size:clamp(20px,5vw,26px); line-height:1.55; color:var(--navy); max-width:460px; margin:0 auto; }
  .parents{ margin-top:24px; font-family:"Pinyon Script", cursive; font-size:clamp(38px,9vw,52px); color:var(--gold-deep); }

  footer{ text-align:center; padding:40px 26px 60px; color:var(--navy-soft); font-size:12px; letter-spacing:1px; position:relative; }
  footer .fcross{ width:20px; height:20px; margin:0 auto 12px; opacity:.7; }
  footer .fcross svg{ width:100%; height:100%; }

  @media (prefers-reduced-motion: reduce){
    .reveal{ transition:none; opacity:1; transform:none; }
    .scroll-hint .arrow, .tap-circle{ animation:none !important; }
    .door{ transition:none; }
    .drip, .ripple{ display:none !important; }
    .church-wrap::before, .archway::after{ display:none !important; }
  }
</style>
</head>
<body class="locked">

