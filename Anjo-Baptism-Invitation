<!-- ===================== INTRO — CHURCH ENTRANCE ===================== -->
<div id="intro">
  <div class="leaf-corner small tl"><svg viewBox="0 0 180 180"><use href="#leafBranch"/></svg></div>
  <div class="leaf-corner small br"><svg viewBox="0 0 180 180"><use href="#leafBranch"/></svg></div>

  <div class="church-wrap">
    <div class="church-text">
      <div class="spire-cross">
        <svg viewBox="0 0 60 76" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g stroke="#C9A227" stroke-width="6" stroke-linecap="square">
            <line x1="30" y1="4" x2="30" y2="58"/>
            <line x1="13" y1="22" x2="47" y2="22"/>
          </g>
        </svg>
      </div>
      <div class="intro-eyebrow">Holy Baptism</div>
    </div>

    <div class="archway">
      <div class="door left"><div class="door-handle"></div></div>
      <div class="door right"><div class="door-handle"></div></div>
    </div>

    <div class="church-text2">
      <div class="intro-name">Anjo P. Jomon</div>
      <div class="tap-hint">
        <div class="tap-circle"><svg viewBox="0 0 24 24" fill="none" stroke="#A47E1B" stroke-width="1.5"><path d="M9 12.5l2.2 2.2L15 10"/><circle cx="12" cy="12" r="9.5"/></svg></div>
        <div class="tap-label">Tap to Open</div>
      </div>
    </div>
  </div>
</div>

<!-- ===================== HERO ===================== -->
<header class="hero">
  <div class="leaf-corner tl"><svg viewBox="0 0 180 180"><use href="#leafBranch"/></svg></div>
  <div class="leaf-corner br"><svg viewBox="0 0 180 180"><use href="#leafBranch"/></svg></div>

  <div class="dove" style="top:9%; right:12%; width:50px;">
    <svg viewBox="0 0 40 20" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="#C9A227" stroke-width="1.6" stroke-linecap="round">
      <path d="M2,15 C8,3 12,3 18,15 C24,3 28,3 34,15"/>
    </svg>
  </div>

  <div class="invite-line">You are warmly invited to</div>

  <div class="cross-flourish">
    <svg viewBox="0 0 64 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g stroke="#C9A227" stroke-width="4.6" stroke-linecap="round">
        <line x1="32" y1="4" x2="32" y2="48"/>
        <line x1="18" y1="19" x2="46" y2="19"/>
      </g>
      <path d="M6,62 C16,58 22,58 32,62 C42,58 48,58 58,62" stroke="#C9A227" stroke-width="1.2" fill="none"/>
      <path d="M30,62 l2,-3 l2,3 l-2,3 Z" fill="#C9A227"/>
    </svg>
  </div>

  <div class="holy">the Holy</div>
  <h1 class="baptism-word">Baptism</h1>

  <div class="of-son"><div class="line"></div><span class="txt">of our son</span><div class="line"></div></div>
  <div class="baby-name">ANJO&nbsp;P.&nbsp;JOMON</div>

  <div class="heart-rule">
    <div class="line"></div>
    <svg viewBox="0 0 24 24" fill="#C9A227"><path d="M12 21s-8-5.2-8-11a4.6 4.6 0 0 1 8-3 4.6 4.6 0 0 1 8 3c0 5.8-8 11-8 11z"/></svg>
    <div class="line r"></div>
  </div>

  <div class="baptism-emblem">
    <svg viewBox="0 0 300 260" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="150" cy="120" r="100" stroke="#C9A227" stroke-width="1" opacity="0.4"/>
      <g transform="translate(150,160)">
        <path d="M -46,0 C -46,-30 -26,-52 0,-52 C 26,-52 46,-30 46,0 C 31,7 15,4 0,16 C -15,4 -31,7 -46,0 Z" fill="none" stroke="#C9A227" stroke-width="2.2"/>
        <path d="M 0,-52 L 0,16" stroke="#C9A227" stroke-width="1" opacity="0.85"/>
        <path d="M -17,-49 C -20,-30 -14,-9 -2,11" stroke="#C9A227" stroke-width="1" opacity="0.8" fill="none"/>
        <path d="M 17,-49 C 20,-30 14,-9 2,11" stroke="#C9A227" stroke-width="1" opacity="0.8" fill="none"/>
      </g>
      <g stroke="#1B3653" stroke-width="6" stroke-linecap="square">
        <line x1="150" y1="36" x2="150" y2="118"/>
        <line x1="124" y1="62" x2="176" y2="62"/>
      </g>
      <circle class="drip" cx="150" cy="78" r="4.2" fill="#7FA3C2"/>
      <circle class="drip d2" cx="140" cy="78" r="3.2" fill="#7FA3C2"/>
      <circle class="drip d3" cx="160" cy="78" r="3.6" fill="#7FA3C2"/>
      <circle class="ripple" cx="150" cy="146" r="7" fill="none" stroke="#7FA3C2" stroke-width="1.4"/>
      <circle class="ripple r2" cx="150" cy="146" r="7" fill="none" stroke="#7FA3C2" stroke-width="1.4"/>
    </svg>
  </div>

  <div class="countdown" id="countdown">
    <div class="unit"><div class="flipcard"><span class="digit-val" id="cd-days">--</span></div><div class="lbl">Days</div></div>
    <div class="colon">:</div>
